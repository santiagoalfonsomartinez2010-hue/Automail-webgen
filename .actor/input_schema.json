{
    "title": "AUTOMAIL WebGen",
    "description": "Genera landing pages automáticas para negocios sin web y los contacta por email",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "ciudad": {
            "title": "Ciudad",
            "type": "string",
            "description": "Ciudad donde buscar negocios (ej: Madrid, Barcelona, Sevilla)",
            "default": "Madrid",
            "editor": "textfield"
        },
        "categoria": {
            "title": "Categoría de negocio",
            "type": "string",
            "description": "Tipo de negocio a buscar (ej: clinica fisioterapia, restaurante, peluqueria)",
            "default": "clinica fisioterapia",
            "editor": "textfield"
        },
        "cantidad": {
            "title": "Número de negocios",
            "type": "integer",
            "description": "Cuántos negocios procesar por ejecución",
            "default": 3,
            "minimum": 1,
            "maximum": 50,
            "editor": "number"
        },
        "anthropicKey": {
            "title": "Anthropic API Key",
            "type": "string",
            "description": "Tu API key de Anthropic (console.anthropic.com)",
            "editor": "textfield",
            "isSecret": true
        },
        "githubToken": {
            "title": "GitHub Personal Access Token",
            "type": "string",
            "description": "Token con permisos de repo",
            "editor": "textfield",
            "isSecret": true
        },
        "githubUser": {
            "title": "GitHub Username",
            "type": "string",
            "description": "Tu nombre de usuario de GitHub",
            "editor": "textfield"
        },
        "githubRepo": {
            "title": "GitHub Repo",
            "type": "string",
            "description": "Nombre del repo con GitHub Pages activo",
            "default": "Automail-webgen",
            "editor": "textfield"
        },
        "gmailUser": {
            "title": "Gmail (tu dirección)",
            "type": "string",
            "description": "Tu dirección de Gmail (ej: tunombre@gmail.com)",
            "editor": "textfield"
        },
        "gmailAppPassword": {
            "title": "Gmail App Password",
            "type": "string",
            "description": "Contraseña de aplicación de Google (16 caracteres, no tu contraseña real)",
            "editor": "textfield",
            "isSecret": true
        }
    },
    "required": ["anthropicKey", "githubToken", "githubUser", "githubRepo", "gmailUser", "gmailAppPassword"]
}
