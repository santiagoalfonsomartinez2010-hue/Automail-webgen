# =============================================
# EMPLEADO IA - Variables de Entorno
# Copia este archivo como .env y rellena los valores
# =============================================

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# --- Google Sheets ---
# ID del Google Sheet (aparece en la URL: /spreadsheets/d/ESTE_ID/edit)
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OlbCVtbZg

# Credenciales de Google API (Service Account JSON convertido a base64)
# Genera en: https://console.cloud.google.com → APIs → Credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL=mi-empleada@mi-proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"

# --- Gmail OAuth2 (para fase 2) ---
GMAIL_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxx
GMAIL_REDIRECT_URI=http://localhost:3001/auth/gmail/callback
GMAIL_REFRESH_TOKEN=1//xxxxxxxxxx

# --- Servidor ---
PORT=3001
FRONTEND_URL=http://localhost:3000

# --- Base de datos ---
DB_PATH=./database.sqlite

# --- Modo desarrollo ---
# true = usar datos simulados en lugar de Gmail/Sheets reales
MODO_SIMULACION=true
